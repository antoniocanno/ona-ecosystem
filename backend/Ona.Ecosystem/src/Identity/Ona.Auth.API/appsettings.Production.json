{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.json",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Information"
        }
      }
      // Adicionar sinks para ferramentas externas (Seq, ElasticSearch, Application Insights):
      /*
      {
          "Name": "Seq",
          "Args": { "serverUrl": "http://seu-seq-server:5341" }
      }
      */
    ]
  },
  "PasswordSettings": {
    "RequiredLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialChar": true
  }
}